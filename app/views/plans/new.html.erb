<%# copy_from/add_spot がある場合はモーダルをスキップして自動作成 %>
<% auto_create = params[:copy_from].present? || params[:add_spot].present? %>
<% create_url = plans_path(copy_from: params[:copy_from], add_spot: params[:add_spot]) %>

<div class="plan-entry" data-controller="myroute-tab--entry" data-myroute-tab--entry-has-plan-value="<%= @latest_plan.present? && !auto_create %>">
  <%# 既存プランがある場合: モーダル表示（copy_from/add_spot時はスキップ） %>
  <% if @latest_plan && !auto_create %>
    <div class="plan-entry-modal" data-myroute-tab--entry-target="modal">
      <div class="plan-entry-modal__overlay"></div>
      <div class="plan-entry-modal__dialog">
        <h2 class="plan-entry-modal__title">プランを作成しますか？</h2>

        <div class="plan-entry-modal__latest">
          <p class="plan-entry-modal__latest-label">前回のプラン</p>
          <div class="plan-entry-modal__latest-header">
            <div class="plan-entry-modal__latest-icon">
              <i class="fa-solid fa-file-lines"></i>
            </div>
            <div class="plan-entry-modal__latest-info">
              <p class="plan-entry-modal__latest-title"><%= plan_title(@latest_plan) %></p>
              <p class="plan-entry-modal__latest-date"><%= format_datetime(@latest_plan.updated_at) %> 更新</p>
            </div>
          </div>

          <% if @latest_plan_spots.any? %>
            <div class="plan-entry-modal__spots">
              <% @latest_plan_spots.first(3).each.with_index(1) do |plan_spot, i| %>
                <div class="plan-entry-modal__spot-item">
                  <span class="plan-entry-modal__spot-number"><%= i %></span>
                  <span><%= plan_spot.spot.name %></span>
                </div>
              <% end %>
              <% if @latest_plan_spots.size > 3 %>
                <p class="plan-entry-modal__spots-more">他 <%= @latest_plan_spots.size - 3 %>件</p>
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="plan-entry-modal__actions">
          <button type="button"
                  class="btn plan-entry-modal__btn plan-entry-modal__btn--new"
                  data-controller="ui--create-plan-trigger"
                  data-action="click->ui--create-plan-trigger#create">
            <i class="fa-solid fa-plus me-2"></i>新規作成
          </button>
          <%= link_to edit_plan_path(@latest_plan), class: "btn plan-entry-modal__btn plan-entry-modal__btn--continue" do %>
            <i class="fa-solid fa-arrow-right me-2"></i>続きから
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# 既存プランがない場合: 自動でプラン作成を開始（非表示ボタンを自動クリック） %>
  <div class="plan-entry-loading" data-myroute-tab--entry-target="loading">
    <div class="plan-entry-loading__spinner">
      <i class="fa-solid fa-spinner fa-spin fa-2x"></i>
    </div>
    <p class="plan-entry-loading__text">プランを準備しています...</p>
  </div>

  <%# 自動発火用の非表示ボタン %>
  <button type="button"
          class="d-none"
          data-myroute-tab--entry-target="autoTrigger"
          data-controller="ui--create-plan-trigger"
          data-ui--create-plan-trigger-url-value="<%= create_url %>"
          data-action="click->ui--create-plan-trigger#create">
  </button>
</div>
